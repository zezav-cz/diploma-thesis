# Logging
LOGGING.LEVEL=info
LOGGING.FORMAT=txt

# Downloader
DOWNLOADER.MAX_WORKERS=10
DOWNLOADER.TIMEOUT_SECONDS=30

# SeaweedFS Configuration
SEAWEEDFS.MASTER_URL=http://localhost:9333
SEAWEEDFS.FILER_URL=http://localhost:8888
SEAWEEDFS.TIMEOUT_SECONDS=30
SEAWEEDFS.CHUNK_SIZE_MB=2
# Set to true to use mock uploader (only makes API calls, no actual SeaweedFS upload)
SEAWEEDFS.USE_MOCK=true
SEAWEEDFS.USE_FAKE=true

# Database API Configuration
DATABASE_API.URL=http://localhost:8000

# Kafka
KAFKA.BROKERS=localhost:9092
KAFKA.TOPIC=image-downloads
KAFKA.PRODUCER_TOPIC=image-uploaded
KAFKA.CONSUMER_GROUP=image-downloader-group

# Health Check
HEALTH.PORT=8081
HEALTH.KAFKA_CHECK_TIMEOUT_SECONDS=5
HEALTH.STARTUP_GRACE_PERIOD_SECONDS=30

# Metrics
METRICS.PORT=9090
