{
  "openapi": "3.1.0",
  "info": {
    "title": "Image Processor API v1",
    "summary": "Image metadata processor with FastAPI and asyncpg",
    "description": "Image metadata processor API.\n\n## Features\n- Store and retrieve image metadata\n- Track failed download attempts\n- Health check endpoints\n",
    "contact": {
      "name": "Jan Trojak",
      "email": "jan.trojak@recombee.com"
    },
    "version": "1.0.0"
  },
  "paths": {
    "/": {
      "get": {
        "tags": [
          "Root"
        ],
        "summary": "Root",
        "description": "Root endpoint for API v1.",
        "operationId": "root__get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": {
                    "type": "string"
                  },
                  "type": "object",
                  "title": "Response Root  Get"
                }
              }
            }
          }
        }
      }
    },
    "/images": {
      "post": {
        "tags": [
          "Images"
        ],
        "summary": "Create image",
        "description": "Create a new image record in the database. The stored_at timestamp will be automatically set to NOW().",
        "operationId": "create_image_images_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ImageCreate"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Image"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/images/by-path": {
      "get": {
        "tags": [
          "Images"
        ],
        "summary": "Get image by path",
        "description": "Retrieve an image by its store_collection and filepath",
        "operationId": "get_image_by_path_images_by_path_get",
        "parameters": [
          {
            "name": "store_collection",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "description": "Storage collection name",
              "title": "Store Collection"
            },
            "description": "Storage collection name"
          },
          {
            "name": "filepath",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "description": "File path within the collection",
              "title": "Filepath"
            },
            "description": "File path within the collection"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Image"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/images/{image_id}": {
      "get": {
        "tags": [
          "Images"
        ],
        "summary": "Get image by ID",
        "description": "Retrieve an image by its database ID",
        "operationId": "get_image_by_id_images__image_id__get",
        "parameters": [
          {
            "name": "image_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "title": "Image Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Image"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": [
          "Images"
        ],
        "summary": "Delete image by ID",
        "description": "Delete an image by its ID. This will also cascade delete all associated download attempts.",
        "operationId": "delete_image_images__image_id__delete",
        "parameters": [
          {
            "name": "image_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "title": "Image Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": true,
                  "title": "Response Delete Image Images  Image Id  Delete"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/failed-downloads-attempts/fail": {
      "post": {
        "tags": [
          "Failed Downloads Attempts"
        ],
        "summary": "Record failed download attempt",
        "description": "Record a failed download attempt. If the image doesn't exist, creates a stub image record first.",
        "operationId": "record_failed_download_failed_downloads_attempts_fail_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/FailedDownloadRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FailedDownloadAttempt"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/failed-downloads-attempts/failed": {
      "get": {
        "tags": [
          "Failed Downloads Attempts"
        ],
        "summary": "List failed download attempts",
        "description": "Retrieve all failed download attempts with optional time period filtering and pagination",
        "operationId": "list_failed_download_attempts_failed_downloads_attempts_failed_get",
        "parameters": [
          {
            "name": "from_date",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string",
                  "format": "date-time"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Start date (inclusive) for filtering attempts",
              "title": "From Date"
            },
            "description": "Start date (inclusive) for filtering attempts"
          },
          {
            "name": "to_date",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string",
                  "format": "date-time"
                },
                {
                  "type": "null"
                }
              ],
              "description": "End date (inclusive) for filtering attempts",
              "title": "To Date"
            },
            "description": "End date (inclusive) for filtering attempts"
          },
          {
            "name": "offset",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 0,
              "description": "Number of records to skip",
              "default": 0,
              "title": "Offset"
            },
            "description": "Number of records to skip"
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "maximum": 1000,
              "minimum": 1,
              "description": "Maximum number of records to return",
              "default": 100,
              "title": "Limit"
            },
            "description": "Maximum number of records to return"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/FailedDownloadAttempt"
                  },
                  "title": "Response List Failed Download Attempts Failed Downloads Attempts Failed Get"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/failed-downloads-attempts/{attempt_id}": {
      "get": {
        "tags": [
          "Failed Downloads Attempts"
        ],
        "summary": "Get failed download attempt by ID",
        "description": "Retrieve a specific failed download attempt by its ID",
        "operationId": "get_failed_download_attempt_failed_downloads_attempts__attempt_id__get",
        "parameters": [
          {
            "name": "attempt_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "title": "Attempt Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FailedDownloadAttempt"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    }
