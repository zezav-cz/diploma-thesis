# Database configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/image_processor

# Database pool configuration
DB_POOL_MIN_SIZE=10
DB_POOL_MAX_SIZE=20
DB_POOL_MAX_QUERIES=50000
DB_POOL_MAX_INACTIVE_CONNECTION_LIFETIME=300.0

# Logging configuration
# LOG_LEVEL options: TRACE (shows DB queries), DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
LOG_FORMAT=JSON

# Server configuration
HOST=0.0.0.0
PORT=8000

EXPOSE_METRICS=True
